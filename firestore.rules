rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read/write their own jobs
    match /jobs/{jobId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow create: if request.auth != null;
    }
    
    // Allow users to read their own execution envelopes
    match /execution_envelopes/{envId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.user_id;
      allow write: if false; // Only server-side worker/api should write
    }
    
    // Allow read access to canonical agents (for display in TaskComposer)
    match /agents/{agentId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    
    // Allow read access to traces for the user's jobs
    match /execution_traces/{traceId} {
      allow read: if request.auth != null; // Ideally filter by job/env ownership
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
