rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow users to read/write their own jobs
    match /jobs/{jobId} {
      allow read, write: if true;
    }
    
    // Allow users to read their own execution envelopes
    match /execution_envelopes/{envId} {
      allow read: if true;
      allow write: if true; 
    }
    
    // Allow read access to canonical agents (for display in TaskComposer)
    match /agents/{agentId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Allow read access to traces for the user's jobs
    match /execution_traces/{traceId} {
      allow read: if true; 
    }
    
    // Allow users to manage their own intelligence provider configs
    match /org_intelligence_providers/{targetUserId} {
      allow read, write: if request.auth != null;
    }

    // ── Phase 3: Knowledge Base & Instructions ──────────────────────────────
    
    // Knowledge Collections metadata
    match /user_knowledge_collections/{userId}/collections/{collId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Knowledge Chunks (read by anyone with access to collection, write by owner)
    match /user_knowledge_chunks/{collId}/chunks/{chunkId} {
      allow read: if true; // Chunks are retrieved via collectionId lookup
      allow write: if request.auth != null; // Managed by upload API
    }

    // Instruction Profiles
    match /user_instruction_profiles/{userId}/profiles/{profileId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
