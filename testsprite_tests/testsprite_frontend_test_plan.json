[
  {
    "id": "TC001",
    "title": "Launch a COO protocol task and verify it appears as assigned in the activity log",
    "description": "Verifies an authenticated user can create a COO task and see it recorded in the UI activity log with status assigned.",
    "category": "Task Dispatch",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "action",
        "description": "Click the \"Launch Mission Control\" button"
      },
      {
        "type": "action",
        "description": "Select \"COO\" from the operation protocol dropdown"
      },
      {
        "type": "action",
        "description": "Type \"Draft a 3-step execution plan for today’s top priority mission and assign responsibilities.\" into the terminal objective textarea"
      },
      {
        "type": "action",
        "description": "Click the \"Launch Agent Task\" button"
      },
      {
        "type": "assertion",
        "description": "Verify the activity log shows a new job entry with status text \"assigned\""
      }
    ]
  },
