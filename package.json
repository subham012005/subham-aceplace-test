{
  "name": "aceplace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker": "cross-env NODE_OPTIONS='--max-old-space-size=256' ts-node -r tsconfig-paths/register apps/runtime-worker/src/index.ts",
    "worker:build": "tsc --build apps/runtime-worker/tsconfig.json",
    "worker:start": "cross-env NODE_OPTIONS='--max-old-space-size=256' node apps/runtime-worker/dist/index.js",
    "test:e2e": "vitest run apps/runtime-worker/src/__tests__/e2e-runtime.test.ts",
    "audit": "npm audit --audit-level=moderate",
    "certify": "ts-node --project tsconfig.json -e \"require('./scripts/phase2-live-certification.ts')\""
  },
  "dependencies": {
    "@aceplace/runtime-core": "*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "firebase": "^12.9.0",
    "firebase-admin": "^10.1.0",
    "gsap": "^3.14.2",
    "lucide-react": "^0.574.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "firebase-tools": "^1.2.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "jsonwebtoken": "^9.0.0",
    "esbuild": "^0.25.0",
    "@google-cloud/firestore": ">=7.11.7",
    "@tootallnate/once": "^3.0.1",
    "vite": "^6.4.2",
    "hono": "^4.12.12",
    "@hono/node-server": "^1.19.13",
    "uuid": "11.1.0",
    "@anthropic-ai/sdk": "^0.33.1",
    "fast-xml-parser": ">=5.7.0",
    "postcss": ">=8.5.10"
  }
}
